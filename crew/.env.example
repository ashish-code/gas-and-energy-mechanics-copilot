# ── LLM ─────────────────────────────────────────────────────────────────────
# CrewAI reads MODEL to select the LLM for all agents.
# GPT-OSS 120B is served via Amazon Bedrock (same model as the Strands copilot).
MODEL=bedrock/openai.gpt-oss-120b-1:0

# ── AWS credentials ───────────────────────────────────────────────────────────
# Same credentials used by the main copilot application.
AWS_PROFILE=default
AWS_DEFAULT_REGION=us-east-1
# Or explicit keys:
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...

# ── RAG index ─────────────────────────────────────────────────────────────────
# Points to the shared FAISS index one level up in the repo.
# Override if running from a different working directory.
RAG_INDEX_DIR=../data/rag_index

# ── Bedrock embedding ─────────────────────────────────────────────────────────
BEDROCK_EMBEDDING_MODEL=amazon.titan-embed-text-v2:0
BEDROCK_EMBEDDING_REGION=us-east-1

# ── Retrieval ─────────────────────────────────────────────────────────────────
RAG_TOP_K=5
