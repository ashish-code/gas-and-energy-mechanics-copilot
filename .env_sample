# Gas & Energy Mechanics Copilot — Environment Configuration
# Source this file before running: source .env

# OpenAI API Key (for RAG index building; Bedrock used at runtime)
export OPENAI_API_KEY=""

# AWS Profile (for Bedrock access: Amazon Titan Embeddings + Nova Lite)
export AWS_PROFILE="default"

# Application Configuration
export CONFIG_DIR="./config"
